+fn run_analyze_via_headless(
+    project_path: &std::path::Path,
+    ghidra_install_dir: &std::path::Path,
+    config: &Config,
+    args: &cli::AnalyzeArgs,
+    quiet: bool,
+) -> anyhow::Result<serde_json::Value> {
+    use serde_json::json;
+
+    let existing_bridge_port = bridge::is_bridge_running(project_path);
+    let current_bridge_program = existing_bridge_port.and_then(|port| {
+        let client = BridgeClient::new(port);
+        client
+            .bridge_info()
+            .ok()
+            .and_then(|info| {
+                info.get("current_program")
+                    .and_then(|v| v.as_str().map(ToOwned::to_owned))
+            })
+    });
+
+    let program_name = args
+        .program
+        .clone()
+        .or(current_bridge_program)
+        .or_else(|| config.get_default_program())
+        .ok_or_else(|| {
+            anyhow::anyhow!(
+                "No program specified. Pass --program, set a default program, or run analyze with a bridge that already has a current program."
+            )
+        })?;
+
+    if let Some(port) = existing_bridge_port {
+        let client = BridgeClient::new(port);
+        let _ = client.open_program(&program_name);
+        bridge::stop_bridge(project_path)?;
+    }
+
+    let headless_script = bridge::find_headless_script(ghidra_install_dir)?;
+    let ghidra_project_dir = project_path.parent().unwrap_or(project_path);
+    let ghidra_project_name = project_path
+        .file_name()
+        .map(|name| name.to_string_lossy().to_string())
+        .unwrap_or_else(|| "project".to_string());
+
+    let mut cmd = Command::new(&headless_script);
+    cmd.arg(ghidra_project_dir)
+        .arg(&ghidra_project_name)
+        .arg("-process")
+        .arg(&program_name);
+
+    if args.detach {
+        cmd.stdin(Stdio::null())
+            .stdout(Stdio::null())
+            .stderr(Stdio::null());
+        let child = cmd
+            .spawn()
+            .map_err(|e| anyhow::anyhow!("Failed to start analyzeHeadless: {}", e))?;
+
+        return Ok(json!({
+            "command": "analyze",
+            "status": "success",
+            "data": {
+                "program": program_name,
+                "detached": true,
+                "pid": child.id()
+            }
+        }));
+    }
+
+    if !quiet {
+        eprintln!("Analyzing {}...", program_name);
+    }
+
+    let output = cmd
+        .output()
+        .map_err(|e| anyhow::anyhow!("Failed to run analyzeHeadless: {}", e))?;
+
+    if !output.status.success() {
+        let stdout = String::from_utf8_lossy(&output.stdout);
+        let stderr = String::from_utf8_lossy(&output.stderr);
+        let stdout_tail: Vec<_> = stdout.lines().rev().take(20).collect();
+        let stderr_tail: Vec<_> = stderr.lines().rev().take(20).collect();
+        let mut detail = String::new();
+        if !stdout_tail.is_empty() {
+            detail.push_str("\nLast stdout:\n");
+            for line in stdout_tail.into_iter().rev() {
+                detail.push_str(line);
+                detail.push('\n');
+            }
+        }
+        if !stderr_tail.is_empty() {
+            detail.push_str("Last stderr:\n");
+            for line in stderr_tail.into_iter().rev() {
+                detail.push_str(line);
+                detail.push('\n');
+            }
+        }
+        anyhow::bail!(
+            "analyzeHeadless failed with status {}{}",
+            output.status,
+            detail
+        );
+    }
+
+    let port =
+        bridge::ensure_bridge_running(project_path, ghidra_install_dir, BridgeStartMode::Project)?;
+    let client = BridgeClient::new(port);
+    verify_bridge(&client)?;
+    client.open_program(&program_name)?;
+    let data = client.program_info()?;
+
+    if !quiet {
+        eprintln!("Analysis complete!");
+    }
+
+    Ok(json!({
+        "command": "analyze",
+        "status": "success",
+        "data": data
+    }))
+}
+
 fn is_unknown_command_error(err: &anyhow::Error) -> bool {
     err.to_string().contains("Unknown command:")
 }
